# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ─── Auto-downloaded Android SDK (build-android.sh) ──────────────────────────
.android-sdk/

# ─── Android build outputs ───────────────────────────────────────────────────
android/app/build/
android/build/
android/.gradle/
android/local.properties
*.apk
*.aab
*.ap_
*.aar

# ─── Capacitor generated / cached files ──────────────────────────────────────
# android/ is fully generated by `npx cap add android` + `npx cap sync`
# build-android.sh runs both automatically when needed
android/
dist/
www/

# ─── Release signing — NEVER commit keystores or signing configs ──────────────
*.jks
*.keystore
*.p12
key.properties
release-signing.properties

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ─── Logs & temp ──────────────────────────────────────────────────────────────
*.log
*.tmp
logs/
